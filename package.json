{
  "name": "lethe-html-alpha",
  "version": "0.1.0",
  "private": true,
  "description": "LETHE HTML alpha prototype with AI playability test tooling.",
  "scripts": {
    "ai:test": "node alpha_test/src/run_alpha.js --runs 1000 --stages 2 --seed 20260601 --echo 0.50 --ui 0.78 --out alpha_test/outputs/default",
    "ai:test:quick": "node alpha_test/src/run_alpha.js --runs 120 --stages 2 --seed quick --echo 0.50 --ui 0.78 --out alpha_test/outputs/quick",
    "ai:test:heavy": "node alpha_test/src/run_alpha.js --runs 5000 --stages 3 --seed heavy --echo 0.50 --ui 0.78 --out alpha_test/outputs/heavy",
    "ai:sweep": "node alpha_test/src/sweep.js --runs 300 --stages 2 --echo 0.40,0.50,0.60,0.70,0.80 --ui 0.45,0.62,0.78 --out alpha_test/outputs/sweep",
    "report": "node scripts/build_report.js",
    "report:check": "node scripts/check_report_units.js",
    "report:discord": "npm run report && node scripts/send_discord_report.js",
    "report:discord:dry": "node scripts/send_discord_report.js --dry-run",
    "report:discord:unit": "npm run report && node scripts/send_discord_report.js --latest-section",
    "report:discord:unit:dry": "node scripts/send_discord_report.js --dry-run --latest-section",
    "codex:notice": "node scripts/send_codex_notice.js",
    "codex:notice:dry": "node scripts/send_codex_notice.js --dry-run",
    "review:claude": "node scripts/ask_claude_review.js",
    "review:claude:dry": "node scripts/ask_claude_review.js --dry-run",
    "review:codex": "node scripts/ask_codex_review.js",
    "review:codex:dry": "node scripts/ask_codex_review.js --dry-run",
    "planning:pipeline": "node scripts/run_planning_pipeline.js",
    "planning:pipeline:auto": "node scripts/run_planning_pipeline.js --provider auto",
    "planning:pipeline:double": "node scripts/run_planning_pipeline.js --provider double",
    "planning:pipeline:dry": "node scripts/run_planning_pipeline.js --dry-run",
    "planning:pipeline:prompt": "node scripts/run_planning_pipeline.js --provider none",
    "planning:pipeline:codex": "node scripts/run_planning_pipeline.js --provider codex",
    "planning:pipeline:claude": "node scripts/run_planning_pipeline.js --provider claude",
    "doctor": "node scripts/check_local_pipeline.js",
    "doctor:deep": "node scripts/check_local_pipeline.js --deep",
    "qa:identity": "node scripts/run_browser_identity_qa.js",
    "qa:pressure": "node scripts/run_browser_pressure_qa.js",
    "qa:tactical": "node scripts/run_browser_pressure_qa.js --mode tactical",
    "qa:postloss": "node scripts/run_browser_pressure_qa.js --mode postloss",
    "qa:postloss:trusted": "node scripts/run_trusted_postloss_gate.js",
    "autopilot:preflight": "node scripts/autopilot_preflight.js --external",
    "autopilot:preflight:local": "node scripts/autopilot_preflight.js",
    "autopilot:preflight:dry": "node scripts/autopilot_preflight.js --dry-run",
    "overnight:loop": "node scripts/run_overnight_loop.js",
    "overnight:loop:dry": "node scripts/run_overnight_loop.js --dry-run",
    "dev:loop": "node scripts/run_autonomous_dev_loop.js",
    "dev:loop:dry": "node scripts/run_autonomous_dev_loop.js --dry-run",
    "playtest:summary": "node scripts/summarize_playtests.js",
    "playtest:summary:dry": "node scripts/summarize_playtests.js --dry-run",
    "playtest:package": "node scripts/prepare_playtest_build.js",
    "playtest:package:dry": "node scripts/prepare_playtest_build.js --dry-run"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
